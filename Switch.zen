"""
Switch - SPST momentary push button (the Morse key), APEM MJTP1243 6x3.5mm.
"""

A = io(Net)
B = io(Net)

Component(
    name="SW",
    part=Part(mpn="MJTP1243", manufacturer="APEM"),
    symbol=Symbol(library="@kicad-symbols/Switch.kicad_sym", name="SW_Push"),
    footprint=File("@kicad-footprints/Button_Switch_THT.pretty/SW_PUSH_1P1T_6x3.5mm_H4.3_APEM_MJTP1243.kicad_mod"),
    prefix="SW",
    pins={
        "1": A,
        "2": B,
    },
)
